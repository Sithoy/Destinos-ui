DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://www.dpmundo.com,https://dpmundo.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://www.dpmundo.com,https://dpmundo.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DATABASE_SSL_REQUIRE=True
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
